# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-strong-random-string
APP_URL=https://yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/ziva

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@yourdomain.com

# ── Admin login ───────────────────────────────────────────────────────────────
# Username (plaintext is fine — it's not a secret in the same way).
ADMIN_USERNAME=your-admin-username

# Password must be stored as a bcrypt hash. Generate it once:
#   python -c "from flask_bcrypt import Bcrypt; print(Bcrypt().generate_password_hash('yourpassword').decode())"
# Then paste the output below.
ADMIN_PASSWORD_HASH=$2b$12$replacethiswitharealbcrypthashxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Redis (optional, falls back to in-memory rate limiting) ──────────────────
# REDIS_URL=redis://localhost:6379
